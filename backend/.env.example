# Supabase (free, cloud): postgresql+asyncpg://postgres.xxx:pass@aws-0-region.pooler.supabase.com:6543/postgres
# Local: postgresql+asyncpg://postgres:password@localhost:5432/satellite_intel
DATABASE_URL=

